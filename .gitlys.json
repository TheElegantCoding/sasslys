{
  "lintStaged": {
    "*.ts": "bunx tsc --noEmit",
    "*.{ts,js,json,yml,yaml}": "bunx eslint --fix",
    "*.{css,scss}": "bunx stylelint --fix"
  },
  "release": {
    "releaseToGithub": true
  },
  "changelog": {
    "changelogPath": "CHANGELOG.md",
    "generateChangelog": true
  },
  "packageManager": "bun"
}