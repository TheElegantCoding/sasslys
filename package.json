{
  "name": "sasslys",
  "description": "📦️ A lightweight, modular Sass framework based on design tokens, utility helpers, and fluid typography for rapid layout development.",
  "author": "Luis Monsalve",
  "version": "1.0.0",
  "homepage": "https://github.com/TheElegantCoding/sasslys#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheElegantCoding/sasslys.git"
  },
  "keywords": [
    "github",
    "git",
    "clean-code",
    "sass",
    "sass-mixins",
    "sass-library",
    "scss",
    "sass-modules"
  ],
  "bugs": {
    "url": "https://github.com/TheElegantCoding/sasslys/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/main.scss",
    "./config": "./src/_config.scss"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=22.17.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "postinstall": "bunx gitlys init",
    "build": "sass src/main.scss dist/main.css --style=compressed --no-source-map",
    "lint": "eslint --fix",
    "release": "bun run build && bunx gitlys release"
  },
  "dependencies": {
    "sass": "1.99.0"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "eslint-config-universal-code": "^1.0.19",
    "gitlys": "^2.2.0",
    "stylelint-config-universal-code": "1.0.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
